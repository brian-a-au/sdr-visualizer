<section id="changes-view" class="view view-changes" hidden>
  <div class="changes-header ui">
    <div id="changes-summary" class="changes-summary"></div>
    <div class="changes-search-row">
      <label class="search-label" for="changes-search">Filter</label>
      <input
        type="search"
        id="changes-search"
        placeholder="Filter changes by name or id…"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
  </div>
  <div id="changes-body" class="changes-body"></div>
</section>
