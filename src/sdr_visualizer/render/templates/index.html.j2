<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }}</title>
<style>
{{ css | safe }}
</style>
</head>
<body>
<header class="header">
  <div class="header-inner">
    <div class="brand">
      <span class="eyebrow">Implementation Visualizer</span>
      <h1>{{ meta.instance_name }}</h1>
      <div class="subtitle ui">
        <span class="platform-tag platform-{{ meta.platform }}">{{ meta.platform | upper }}</span>
        <span class="instance-id mono">{{ meta.instance_id }}</span>
        {% if meta.snapshot_taken_at %}
          <span class="separator">·</span>
          <span>Snapshot {{ meta.snapshot_taken_at }}</span>
        {% endif %}
      </div>
    </div>
    <div class="meta-strip ui">
      <div class="meta-item">
        <span class="meta-label">Components</span>
        <span class="meta-value">{{ component_count }}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Metrics</span>
        <span class="meta-value">{{ metric_count }}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Dimensions</span>
        <span class="meta-value">{{ dimension_count }}</span>
      </div>
      {% if derived_field_count %}
      <div class="meta-item">
        <span class="meta-label">Derived</span>
        <span class="meta-value">{{ derived_field_count }}</span>
      </div>
      {% endif %}
      <div class="meta-item">
        <span class="meta-label">Segments</span>
        <span class="meta-value">{{ segment_count }}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Calc metrics</span>
        <span class="meta-value">{{ calc_metric_count }}</span>
      </div>
    </div>
  </div>
</header>

<nav class="view-nav ui">
  <button type="button" class="view-button is-active" data-view="catalog">Catalog</button>
  <button type="button" class="view-button" data-view="graph" disabled title="Graph view coming in Phase 4">Reference graph</button>
</nav>

{% include "catalog.html.j2" %}

<aside id="detail-panel" class="detail-panel" aria-hidden="true">
  <div class="detail-panel-inner">
    <button type="button" id="detail-close" class="detail-close ui" aria-label="Close detail panel">×</button>
    <div id="detail-body"></div>
  </div>
</aside>
<div id="detail-overlay" class="detail-overlay" aria-hidden="true"></div>

<footer class="footer ui">
  <span>Generated by sdr-visualizer {{ meta.visualizer_version }}</span>
  <span class="separator">·</span>
  <span>See also <a href="https://github.com/brian-a-au/sdr-grader" rel="noopener">sdr-grader</a> for implementation grading.</span>
</footer>

<script id="sdr-data" type="application/json">{{ payload_json | safe }}</script>
<script>
{{ js | safe }}
</script>
</body>
</html>
